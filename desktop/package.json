{
  "name": "deepseek-plus-plus-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron desktop shell for DeepSeek++ (wraps chat.deepseek.com + the extension content scripts)",
  "main": "main.cjs",
  "scripts": {
    "stage": "node ../scripts/copy-dist-to-desktop.mjs && node ../scripts/copy-shell-host-to-desktop.mjs",
    "prestart": "npm run stage",
    "start": "electron .",
    "predist": "npm run stage",
    "postdist": "node scripts/set-icon.cjs",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "github.zhu1090093659.deepseekpp.desktop",
    "productName": "DeepSeek++",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "main.cjs",
      "preload-chat.cjs",
      "preload-background.cjs",
      "preload-sidebar.cjs",
      "navigation-guard.cjs",
      "background.html",
      "dpp/**/*",
      "native/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility",
      "icon": "build/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "rcedit": "^5.0.1"
  }
}
