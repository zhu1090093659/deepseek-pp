{
  "name": "deepseek-plus-plus",
  "description": "Agentic memory, skills, agentic execution, automation, and MCP tools for DeepSeek",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:chrome": "wxt build --browser chrome",
    "build:edge": "wxt build --browser edge",
    "build:firefox": "wxt build --browser firefox --mv3",
    "build:android": "npm run build:chrome && node scripts/copy-to-android-assets.mjs",
    "android:assemble:debug": "node scripts/run-android-gradle.mjs assembleDebug",
    "test:android": "node scripts/run-android-gradle.mjs testDebugUnitTest",
    "build:all": "npm run build:chrome && npm run build:edge && npm run build:firefox",
    "zip": "wxt zip",
    "zip:chrome": "wxt zip --browser chrome",
    "zip:edge": "wxt zip --browser edge",
    "zip:firefox": "wxt zip --browser firefox --mv3",
    "zip:sources": "node scripts/package-sources.mjs",
    "zip:all": "npm run zip:chrome && npm run zip:edge && npm run zip:firefox && npm run zip:sources",
    "submit:chrome:dry": "wxt submit --dry-run --chrome-zip dist/deepseek-plus-plus-$npm_package_version-chrome.zip",
    "submit:chrome:upload": "wxt submit --chrome-zip dist/deepseek-plus-plus-$npm_package_version-chrome.zip --chrome-skip-submit-review",
    "submit:chrome": "wxt submit --chrome-zip dist/deepseek-plus-plus-$npm_package_version-chrome.zip --chrome-publish-target default",
    "test": "vitest run",
    "compile": "tsc --noEmit",
    "audit:prod": "npm audit --audit-level=high --omit=dev",
    "verify:workflows": "actionlint",
    "verify:manifest-policy": "node scripts/manifest-policy-check.mjs",
    "verify:extension-utf8": "node scripts/verify-extension-utf8.mjs",
    "verify:release-assets": "node scripts/release-assets-check.mjs",
    "verify:i18n": "node scripts/i18n-locale-check.mjs && node scripts/i18n-coverage-audit.mjs",
    "ci:quality": "npm run verify:workflows && npm run audit:prod && npm run prompt:freeze && npm run compile && npm test && npm run verify:i18n && npm run verify:automation && npm run smoke:mcp && npm run verify:mcp:mock && npm run smoke:shell && npm run smoke:pow && npm run build:all && npm run verify:extension-utf8 && npm run verify:manifest-policy && npm run zip:all && npm run verify:release-assets",
    "shell:install": "node scripts/install-shell-host.mjs",
    "multimodal:install": "npx --yes deepseek-pp-multimodal-mcp",
    "smoke:pow": "node scripts/pow-smoke.mjs",
    "smoke:web": "node scripts/web-search-smoke.mjs",
    "prompt:freeze": "node scripts/prompt-freeze.mjs",
    "smoke:shell": "node scripts/shell-smoke.mjs",
    "smoke:mcp": "node scripts/mcp-smoke.mjs",
    "verify:automation": "node scripts/automation-contract-smoke.mjs",
    "verify:mcp:mock": "node scripts/mcp-live-mock.mjs",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "pyodide": "^314.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "sucrase": "^3.35.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.42",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.1.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  }
}
